# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# kiro
.kiro

# hardening folder (has own git repo)
hardening/

# Markdown files - allow important docs
!DEPLOYMENT-GUIDE.md
!SECURITY-NOTES.md
!ADVANCED-MONITORING-GUIDE.md
!LOCAL-MONITORING-GUIDE.md
!CRON-SETUP-GUIDE.md

# Archive files
*.zip
*.7z
*.7zip
*.rar
*.tar
*.tar.gz
*.tgz

# Backups (database dumps, file backups)
/backups/
backups/

# Uploads (user uploaded files - PDFs, images)
/public/uploads/
public/uploads/

# Log files
*.log

# VSCode settings
.vscode/

# PowerShell scripts (Windows only)
*.ps1

# Test/monitoring/development scripts
test-*.js
stress-test.js
monitor-memory.js
advanced-monitor.js
analyze-memory-log.js
force-gc-test.js
generate-bcrypt-hash.js

# Development/analysis markdown files
check-react-loops.md
ICON-FIX-SUMMARY.md
MEMORY-LEAK-ANALYSIS.md
PRODUCTION-DEPLOYMENT-GUIDE.md

# Security tests folder
security-tests/

