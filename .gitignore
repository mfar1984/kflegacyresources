# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
# /.next/  # COMMENTED: Allow .next for production deployment (shared hosting with limited memory)
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# kiro
.kiro

# Markdown files - ignore all except README.md
*.md
!README.md

# Archive files
*.zip
*.7z
*.7zip
*.rar
*.tar
*.tar.gz
*.tgz

# Backups (database dumps, file backups)
/backups/
backups/

# Uploads (user uploaded files - PDFs, images)
/public/uploads/
public/uploads/

# Log files
*.log

# VSCode settings
.vscode/

# PowerShell scripts (Windows only)
*.ps1

# Test/monitoring/development scripts
test-*.js
stress-test.js
monitor-memory.js
advanced-monitor.js
analyze-memory-log.js
force-gc-test.js
generate-bcrypt-hash.js

# Development/analysis markdown files
# (All .md files ignored except README.md - see above)

# Security tests folder
security-tests/

# Shell scripts for local development
restart-app.sh
start.ps1

# Scripts folder
scripts/
