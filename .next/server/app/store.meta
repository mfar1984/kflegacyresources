{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(site)/layout,_N_T_/(site)/store/layout,_N_T_/(site)/store/page,_N_T_/store"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KHNpdGUp/store/__PAGE__",
    "/!KHNpdGUp/store",
    "/!KHNpdGUp",
    "/_index",
    "/_head"
  ]
}