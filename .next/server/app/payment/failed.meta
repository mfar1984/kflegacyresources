{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(site)/layout,_N_T_/(site)/payment/layout,_N_T_/(site)/payment/failed/layout,_N_T_/(site)/payment/failed/page,_N_T_/payment/failed"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KHNpdGUp/payment/failed/__PAGE__",
    "/!KHNpdGUp/payment/failed",
    "/!KHNpdGUp/payment",
    "/!KHNpdGUp",
    "/_index",
    "/_head"
  ]
}