{
  "version": 1,
  "functions": {
    "/_middleware": {
      "runtime": "nodejs",
      "matchers": [
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?\\/contact(\\.json)?[\\/#\\?]?$",
          "originalSource": "/contact"
        },
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?(?:\\/(.*))(\\.json)?[\\/#\\?]?$",
          "originalSource": "/(.*)"
        }
      ]
    }
  }
}